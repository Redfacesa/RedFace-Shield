{
  "name": "redface-platform",
  "private": true,
  "version": "1.0.0",
  "description": "RedFace Operational Infrastructure Platform — Architecture v1.0",
  "workspaces": [
    "packages/*",
    "packages/operational-kernel/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:local": "node scripts/start-local-db.mjs",
    "db:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "db:migrate": "npm run db:migrate -w @redface/kernel-core",
    "mvp:hijacking": "npm run mvp:hijacking -w @redface/kernel-core",
    "playback:demo": "npm run playback:demo -w @redface/kernel-core",
    "sim:recovery": "npm run sim:recovery -w @redface/mission-simulator",
    "kernel:dev": "npm run dev -w @redface/kernel-api"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@embedded-postgres/darwin-x64": "^18.4.0-beta.17",
    "embedded-postgres": "^18.4.0-beta.17"
  }
}
